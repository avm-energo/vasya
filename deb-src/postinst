DEBVERSION=$(cat /etc/debian_version | cut -d '.' -f1)
dpkg -i /usr/local/share/vasya/nginx/${DEBVERSION}/*.deb
rm -rf /usr/local/share/vasya/nginx
rm /etc/nginx/sites-enabled/default 2>/dev/null
cp /usr/local/share/vasya/vasya.conf /etc/nginx/conf.d/
chown -R www-data:www-data /var/www/vasya
systemctl restart nginx
mkdir -p /avtuk/sonica/vasya/settings
cp /usr/local/share/vasya/settings.ini /avtuk/sonica/vasya/settings/ 2>/dev/null
cp /usr/local/share/vasya/version /var/www/vasya/